# arr-docker-easy configuration
# Copy this file to .env and edit before running docker compose up

# User/Group IDs (run `id -u` and `id -g` to find yours)
PUID=1000
PGID=1000

# Timezone
TZ=America/Chicago

# Where persistent config/data lives
DATA_ROOT=./data

# Where your media lives (TV, movies, downloads)
MEDIA_ROOT=./media

# Port overrides (uncomment to change defaults)
# PROWLARR_PORT=9696
# SONARR_PORT=8989
# RADARR_PORT=7878
# JELLYFIN_PORT=8096
# JELLYSEERR_PORT=5055
# TRANSMISSION_PORT=9091
